# ============================================
# ProjectFlow - Environment Variables
# Copy to .env.local for local development
# ============================================

# --- Database (MongoDB Atlas) ---
DATABASE_URL="mongodb+srv://<user>:<password>@cluster.mongodb.net/projectflow?retryWrites=true&w=majority"

# --- NextAuth.js ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-super-secret-key-min-32-chars-change-this"

# --- OAuth Providers (optional) ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# --- Pusher (Real-time) ---
# Sign up at https://pusher.com (free tier works)
PUSHER_APP_ID=""
PUSHER_APP_KEY=""
PUSHER_APP_SECRET=""
PUSHER_CLUSTER="mt1"
NEXT_PUBLIC_PUSHER_APP_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="mt1"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
